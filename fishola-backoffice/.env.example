# Backend Django « gestion interne » — configuration.
# La BDD est la BDD applicative Fishola PARTAGÉE (PostgreSQL/PostGIS).
# Valeurs par défaut = environnement de recette.

DJANGO_SECRET_KEY=dev-insecure-change-me-in-prod
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=fishola
DB_USER=postgres
DB_PASSWORD=whatever
DB_HOST=localhost
DB_PORT=15432
