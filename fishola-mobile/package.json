    "@types/lodash": "^4.14.167",
    "canvas": "^2.7.0",
    "core-js": "^3.8.2",
    "dexie": "^3.0.3",
    "html2canvas": "^1.0.0-rc.7",
    "leaflet": "^1.7.1",
