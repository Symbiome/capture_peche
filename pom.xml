<?xml version="1.0"?>
<project xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd"
         xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>org.nuiton</groupId>
    <artifactId>pom</artifactId>
    <version>11.7</version>
  </parent>

  <groupId>fr.inrae</groupId>
  <artifactId>fishola</artifactId>
  <version>0.0.1-SNAPSHOT</version>

  <name>Fishola</name>
  <description>Application smartphone en sciences participatives pour la pêche amateur sur les lacs de l’observatoire OLA</description>
  <url>${projectUrl}</url>
  <inceptionYear>2019</inceptionYear>

  <organization>
    <name>INRAE</name>
    <url>https://www.inrae.fr/</url>
  </organization>

  <packaging>pom</packaging>

  <properties>
    <gitlabGroupName>inrae</gitlabGroupName>
    <gitlabProjectName>fishola</gitlabProjectName>

    <quarkusVersion>1.4.2.Final</quarkusVersion>
    <jooqVersion>3.13.2</jooqVersion>
    <flywayVersion>6.4.3</flywayVersion>
    <jacksonVersion>2.11.0</jacksonVersion>
    <postgresqlDriverVersion>42.2.12</postgresqlDriverVersion>
    <testcontainersVersion>1.14.3</testcontainersVersion>

    <maven.compiler.parameters>true</maven.compiler.parameters>

<!--    <javaVersion>14</javaVersion>-->
    <!-- FIXME AThimel 22/01/2020 Pour l'instant on ne peut pas mettre Java 13 à cause de : https://github.com/mojohaus/extra-enforcer-rules/issues/80 et/ou https://github.com/mojohaus/extra-enforcer-rules/pull/93/ -->
    <javaVersion>11</javaVersion>
    <animal.sniffer.skip>true</animal.sniffer.skip>

    <antRunPluginVersion>3.0.0</antRunPluginVersion>
    <dependencyPluginVersion>3.1.2</dependencyPluginVersion>
  </properties>

  <scm>
    <url>https://gitlab.nuiton.org/inrae/fishola</url>
    <connection>scm:git:git@gitlab.nuiton.org:inrae/fishola.git</connection>
    <developerConnection>scm:git:git@gitlab.nuiton.org:inrae/fishola.git</developerConnection>
  </scm>

  <prerequisites>
    <maven>3.6.2</maven>
  </prerequisites>

  <modules>
    <module>fishola-backend</module>
    <module>fishola-mobile</module>
  </modules>

