      </dependency>
      <dependency>
        <groupId>org.testcontainers</groupId>
        <artifactId>postgresql</artifactId>
        <version>${testcontainersVersion}</version>
        <scope>test</scope>
      </dependency>

      <!-- FIXME AThimel 04/06/2020 : Pas besoin de tirer cette dépendance, mais on est obligée de forcer la version en 1.0.2 car la 1.0.3 tire ASM 8 qui fait planter les tests : Unsupported api 524288 -->
      <dependency>
        <groupId>io.quarkus.gizmo</groupId>
        <artifactId>gizmo</artifactId>
        <version>1.0.2.Final</version>
        <scope>test</scope>
      </dependency>

    </dependencies>
  </dependencyManagement>

  <build>
    <pluginManagement>
      <plugins>

        <plugin>
          <groupId>pl.project13.maven</groupId>
          <artifactId>git-commit-id-plugin</artifactId>
          <version>4.0.0</version>
        </plugin>

        <plugin>
          <groupId>cz.habarta.typescript-generator</groupId>
          <artifactId>typescript-generator-maven-plugin</artifactId>
          <version>2.23.603</version>
        </plugin>

        <plugin>
          <groupId>com.github.slavaz</groupId>
          <artifactId>embedded-postgresql-maven-plugin</artifactId>
          <version>1.2.4</version>
        </plugin>

        <plugin>
          <groupId>org.flywaydb</groupId>
          <artifactId>flyway-maven-plugin</artifactId>
          <version>${flywayVersion}</version>
        </plugin>

        <plugin>
          <groupId>org.jooq</groupId>
          <artifactId>jooq-codegen-maven</artifactId>
          <version>${jooqVersion}</version>
        </plugin>

        <plugin>
          <groupId>io.quarkus</groupId>
          <artifactId>quarkus-maven-plugin</artifactId>
          <version>${quarkusVersion}</version>
        </plugin>

        <plugin>
          <groupId>com.github.eirslett</groupId>
          <artifactId>frontend-maven-plugin</artifactId>
          <version>1.10.0</version>
        </plugin>

        <plugin>
          <groupId>org.codehaus.mojo</groupId>
          <artifactId>license-maven-plugin</artifactId>
          <version>${licensePluginVersion}</version>
          <configuration>
            <extraExtensions>
              <vue>html</vue>
            </extraExtensions>
          </configuration>
        </plugin>

      </plugins>
    </pluginManagement>
    <plugins/>
  </build>

  <profiles>

    <!-- Profil temporaire le temps que la synchro NUITON -> Central soit rétablie -->
    <profile>

      <id>nuiton</id>
      <activation>
        <activeByDefault>true</activeByDefault>
      </activation>

      <repositories>
        <!-- nuiton public -->
        <repository>
          <id>nuiton-nexus-repository</id>
          <url>https://nexus.nuiton.org/nexus/content/groups/public/</url>
          <snapshots>
            <enabled>true</enabled>
            <checksumPolicy>fail</checksumPolicy>
          </snapshots>
          <releases>
            <enabled>true</enabled>
            <checksumPolicy>fail</checksumPolicy>
          </releases>
        </repository>
      </repositories>

    </profile>

  </profiles>
</project>
